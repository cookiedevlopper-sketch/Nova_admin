local function executeCommand(input)
 input = input:match("^%s*(.-)%s*$")
 if input == "" or input:sub(1, #PREFIX) ~= PREFIX then return end
 local content = input:sub(#PREFIX + 1)
 local parts = {}
 for word in content:gmatch("%S+") do
 table.insert(parts, word)
 end
 if #parts == 0 then return end
 local cmdName = parts[1]:lower()
 local args = {}
 for i = 2, #parts do table.insert(args, parts[i]) end
 if commands[cmdName] then
 log("> " .. input,"system")
 local ok, err = pcall(commands[cmdName].func, args)
 if not ok then
 log("Error: " .. tostring(err), "error")
 end
 else
 log("Unknown command: " .. cmdName .. " (type /help)", "error")
 end
end

CmdBox.FocusLost:Connect(function(entered)
 if entered then
 executeCommand(CmdBox.Text)
 CmdBox.Text = ""
 end
end)

player.Chatted:Connect(function(msg)
